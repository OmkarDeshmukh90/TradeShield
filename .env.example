APP_ENV=dev
DATABASE_URL=sqlite:///./tradeshield.db
AUTO_CREATE_SCHEMA=true
INGESTION_INTERVAL_SECONDS=900
WORKER_POLL_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=20
HEALTH_INGESTION_STALE_MINUTES=45
ENABLED_CONNECTORS=all
INGESTION_ERROR_BACKOFF_MINUTES=30
INGESTION_BACKOFF_ERROR_THRESHOLD=3
DEMO_MODE=false
DEMO_SCENARIO=all
MODEL_VERSION=ts-risk-v1.1.0
AUTH_SECRET=change-me-dev-secret
ACCESS_TOKEN_TTL_MINUTES=480
PASSWORD_HASH_ITERATIONS=390000
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ENABLE_DOCS=true
LOG_LEVEL=INFO

ALERT_MAX_ATTEMPTS=5
ALERT_RETRY_BACKOFF_SECONDS=60
ALERT_BATCH_SIZE=50

# Production example
# APP_ENV=prod
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tradeshield
# AUTO_CREATE_SCHEMA=false
# AUTH_SECRET=replace-with-strong-random-secret
# ENABLE_DOCS=false

# Optional external connectors
NEWS_API_KEY=
SPIRE_API_KEY=

# Optional WhatsApp delivery via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Optional email delivery via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
